<% if (title) { %>
<h1><%= title %></h1>
<%- messages() %>
<% } else {
    res.redirect('/')
} %>

<% if (errors) { %>
    <ul class="notice">
    <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
    <% }) %>
    </ul>
<% } %>

<h2>Welcome, <%- accountData.account_firstname %></h2>

<p><a title="Click to update account information" href="/account/update/<%= accountData.account_id %>">Update account information</a></p>
<p><a title="Click to view favorite vehicles" href="/account/favorites">Your Favorite Vehicles</a></p>


<% if (managementAccess) { %>
    <h3>Inventory Management</h3>
    <p><a title="Click to manage inventory" href="/inv/">Manage site inventory</a></p>
    <% } %>